{
  "serviceName": "{{ tfstate `output.worker_ecs_service_name` }}",
  "desiredCount": {{ env `WORKER_DESIRED_COUNT` `1` }},
  "launchType": "FARGATE",
  "platformVersion": "LATEST",
  "availabilityZoneRebalancing": "ENABLED",
  "propagateTags": "NONE",
  "deploymentConfiguration": {
    "deploymentCircuitBreaker": {
      "enable": true,
      "rollback": true
    },
    "maximumPercent": 200,
    "minimumHealthyPercent": 100
  },
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": {{ tfstate `output.private_subnet_ids` }},
      "securityGroups": [
        "{{ tfstate `output.ecs_task_security_group_id` }}"
      ],
      "assignPublicIp": "{{ must_env `WORKER_ASSIGN_PUBLIC_IP` }}"
    }
  }
}

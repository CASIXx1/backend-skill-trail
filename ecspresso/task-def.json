{
  "family": "{{ tfstate `output.api_ecs_service_name` }}",
  "taskRoleArn": "{{ tfstate `output.ecs_task_role_arn` }}",
  "executionRoleArn": "{{ tfstate `output.ecs_task_execution_role_arn` }}",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "{{ must_env `CONTAINER_NAME` }}",
      "image": "{{ tfstate `output.api_ecr_repository_url` }}:{{ must_env `IMAGE_TAG` }}",
      "essential": true,
      "stopTimeout": 30,
      "portMappings": [
        {
          "containerPort": {{ must_env `CONTAINER_PORT` }},
          "hostPort": {{ must_env `CONTAINER_PORT` }},
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "{{ must_env `CONTAINER_PORT` }}"
        },
        {
          "name": "DB_HOST",
          "value": "{{ tfstate `output.database_writer_endpoint` }}"
        },
        {
          "name": "DB_READER_HOST",
          "value": "{{ tfstate `output.database_reader_endpoint` }}"
        },
        {
          "name": "DB_PORT",
          "value": "{{ tfstate `output.database_port` }}"
        },
        {
          "name": "DB_NAME",
          "value": "{{ tfstate `output.database_name` }}"
        }
      ],
      "secrets": [
        {
          "name": "DB_USER",
          "valueFrom": "{{ tfstate `output.database_master_user_secret_arn` }}:username::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "{{ tfstate `output.database_master_user_secret_arn` }}:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awsfirelens"
      }
    },
    {
      "name": "log_router",
      "image": "{{ tfstate `output.firelens_ecr_repository_url` }}:{{ must_env `IMAGE_TAG` }}",
      "essential": true,
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "{{ must_env `AWS_REGION` }}"
        },
        {
          "name": "CLOUDWATCH_LOG_GROUP",
          "value": "{{ tfstate `output.api_log_group_name` }}"
        },
        {
          "name": "NEW_RELIC_LOG_ENDPOINT",
          "value": "{{ tfstate `output.new_relic_log_endpoint` }}"
        }
      ],
      "secrets": [
        {
          "name": "NEW_RELIC_LICENSE_KEY",
          "valueFrom": "{{ tfstate `output.external_service_secret_arn` }}:NEW_RELIC_LICENSE_KEY::"
        }
      ],
      "firelensConfiguration": {
        "type": "fluentbit",
        "options": {
          "enable-ecs-log-metadata": "true",
          "config-file-type": "file",
          "config-file-value": "/fluent-bit/etc/fluent-bit-custom.conf"
        }
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "{{ tfstate `output.api_log_group_name` }}",
          "awslogs-region": "{{ must_env `AWS_REGION` }}",
          "awslogs-stream-prefix": "firelens"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "{{ env `TASK_CPU` `256` }}",
  "memory": "{{ env `TASK_MEMORY` `512` }}",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  }
}

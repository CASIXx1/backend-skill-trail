{
  "serviceName": "{{ tfstate `output.api_ecs_service_name` }}",
  "desiredCount": {{ env `DESIRED_COUNT` `1` }},
  "launchType": "FARGATE",
  "platformVersion": "LATEST",
  "deploymentConfiguration": {
    "maximumPercent": 200,
    "minimumHealthyPercent": 100
  },
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": [
        "{{ tfstate `module.network.aws_subnet.private_1a.id` }}",
        "{{ tfstate `module.network.aws_subnet.private_1c.id` }}"
      ],
      "securityGroups": [
        "{{ tfstate `module.security_groups.aws_security_group.ecs_tasks.id` }}"
      ],
      "assignPublicIp": "{{ must_env `ASSIGN_PUBLIC_IP` }}"
    }
  }
}
